@page "/getting-started"

<PageTitle>Getting Started</PageTitle>

<div style="padding: 20px;">
    <FluentLabel Typo="Typography.H1">Getting Started</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 20px;">
        Start with the basics and explore the Grid component through the examples below.
    </FluentLabel>

    <FluentLabel Typo="Typography.H2">Install via NuGet</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 10px;">
        Brysageek.Grid works in both Blazor WebAssembly and Blazor Server applications.
    </FluentLabel>
    <pre class="example-code-block"><code>dotnet add package Brysageek.Grid</code></pre>

    <FluentLabel Typo="Typography.H2">Update _Imports.razor</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 10px;">
        Add the Grid namespaces once so you can use the components throughout your app.
    </FluentLabel>
    <pre class="example-code-block"><code>@using Brysageek.Grid
@using Brysageek.Grid.Placement</code></pre>

    <FluentMessageBar Intent="MessageIntent.Info" Style="margin: 15px 0;">
        <FluentLabel Typo="Typography.Body">
            Start with the Basic Layouts example to understand the core concepts, then explore more advanced features in the other examples.
        </FluentLabel>
    </FluentMessageBar>

</div>
