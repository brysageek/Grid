@page "/"

<PageTitle>Grid Component Library - Home</PageTitle>

<div style="padding: 20px;">
    <FluentLabel Typo="Typography.H1">Grid Component Library</FluentLabel>
    <FluentLabel Typo="Typography.Body">
        A powerful Blazor grid layout library inspired by XAML Grid controls, providing flexible and responsive layouts for your web applications.
    </FluentLabel>

    <FluentDivider Style="margin: 30px 0;" />

    <FluentLabel Typo="Typography.H2" Style="margin-bottom: 20px;">Features</FluentLabel>
    <Grid Columns="1fr 1fr" Rows="auto auto" Gap="20px" Style="margin: 20px 0;">
        <GridItem ColumnStart="1" RowStart="1">
            <FluentCard Style="padding: 20px; height: 100%;">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 10px;">
                    <FluentLabel Typo="Typography.H4">✨ Flexible Grid System</FluentLabel>
                    <FluentLabel Typo="Typography.Body">
                        Define custom columns and rows using CSS Grid syntax with full control over sizing and spacing
                    </FluentLabel>
                </FluentStack>
            </FluentCard>
        </GridItem>
        <GridItem ColumnStart="2" RowStart="1">
            <FluentCard Style="padding: 20px; height: 100%;">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 10px;">
                    <FluentLabel Typo="Typography.H4">🎯 Precise Item Placement</FluentLabel>
                    <FluentLabel Typo="Typography.Body">
                        Control column/row start positions and spanning with intuitive properties
                    </FluentLabel>
                </FluentStack>
            </FluentCard>
        </GridItem>
        <GridItem ColumnStart="1" RowStart="2">
            <FluentCard Style="padding: 20px; height: 100%;">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 10px;">
                    <FluentLabel Typo="Typography.H4">📐 Alignment Control</FluentLabel>
                    <FluentLabel Typo="Typography.Body">
                        Fine-tune item alignment with JustifySelf and AlignSelf properties for pixel-perfect layouts
                    </FluentLabel>
                </FluentStack>
            </FluentCard>
        </GridItem>
        <GridItem ColumnStart="2" RowStart="2">
            <FluentCard Style="padding: 20px; height: 100%;">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 10px;">
                    <FluentLabel Typo="Typography.H4">📱 Responsive Design</FluentLabel>
                    <FluentLabel Typo="Typography.Body">
                        Create adaptive layouts that work beautifully on any screen size or device
                    </FluentLabel>
                </FluentStack>
            </FluentCard>
        </GridItem>
    </Grid>

    <FluentDivider Style="margin: 30px 0;" />

    <FluentLabel Typo="Typography.H2">Examples & Demos</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 20px;">
        Explore interactive examples to learn how to use the Grid component:
    </FluentLabel>

    <Grid Columns="1fr 1fr" Rows="auto auto auto" Gap="15px">
        <GridItem ColumnStart="1" RowStart="1">
            <FluentCard Class="example-card-accent-muted" Style="height: 100%; cursor: pointer;" @onclick="@(() => NavigateToExample("/basic-layouts"))">
                <FluentLabel Typo="Typography.H4">📊 Basic Layouts</FluentLabel>
                <FluentLabel Typo="Typography.Body">
                    Learn the fundamentals of creating grid layouts with columns and rows
                </FluentLabel>
            </FluentCard>
        </GridItem>
        <GridItem ColumnStart="2" RowStart="1">
            <FluentCard Class="example-card-accent-muted" Style="height: 100%; cursor: pointer;" @onclick="@(() => NavigateToExample("/spanning-examples"))">
                <FluentLabel Typo="Typography.H4">🔲 Spanning Examples</FluentLabel>
                <FluentLabel Typo="Typography.Body">
                    See how items can span across multiple columns and rows
                </FluentLabel>
            </FluentCard>
        </GridItem>
        <GridItem ColumnStart="1" RowStart="2">
            <FluentCard Class="example-card-neutral" Style="height: 100%; cursor: pointer;" @onclick="@(() => NavigateToExample("/alignment-examples"))">
                <FluentLabel Typo="Typography.H4">🎯 Alignment Examples</FluentLabel>
                <FluentLabel Typo="Typography.Body">
                    Control item positioning with JustifySelf and AlignSelf properties
                </FluentLabel>
            </FluentCard>
        </GridItem>
        <GridItem ColumnStart="2" RowStart="2">
            <FluentCard Class="example-card-neutral" Style="height: 100%; cursor: pointer;" @onclick="@(() => NavigateToExample("/responsive-examples"))">
                <FluentLabel Typo="Typography.H4">📱 Responsive Examples</FluentLabel>
                <FluentLabel Typo="Typography.Body">
                    Build adaptive layouts that respond to different screen sizes
                </FluentLabel>
            </FluentCard>
        </GridItem>
        <GridItem ColumnStart="1" RowStart="3">
            <FluentCard Class="example-card-neutral" Style="height: 100%; cursor: pointer;" @onclick="@(() => NavigateToExample("/interactive-playground"))">
                <FluentLabel Typo="Typography.H4">🎮 Interactive Playground</FluentLabel>
                <FluentLabel Typo="Typography.Body">
                    Experiment with grid properties in real-time
                </FluentLabel>
            </FluentCard>
        </GridItem>
        <GridItem ColumnStart="2" RowStart="3">
            <FluentCard Class="example-card-neutral" Style="height: 100%; cursor: pointer;" @onclick="@(() => NavigateToExample("/dashboard"))">
                <FluentLabel Typo="Typography.H4">📈 Dashboard Example</FluentLabel>
                <FluentLabel Typo="Typography.Body">
                    See a complete dashboard layout built with the Grid component
                </FluentLabel>
            </FluentCard>
        </GridItem>
    </Grid>

</div>

@code {
    [Inject] private NavigationManager? Navigation { get; set; }

    private void NavigateToExample(string url)
    {
        Navigation?.NavigateTo(url);
    }
}
