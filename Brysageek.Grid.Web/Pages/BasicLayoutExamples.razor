@page "/basic-layouts"

<PageTitle>Basic Layout Examples</PageTitle>

<div style="padding: 20px;">
    <FluentLabel Typo="Typography.H1">Basic Grid Layouts</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 30px;">
        Learn the fundamentals of creating grid layouts with columns and rows.
    </FluentLabel>

    <FluentDivider Style="margin: 30px 0;" />

    <!-- Example 1: Simple 2x2 Grid -->
    <FluentLabel Typo="Typography.H2">1. Simple 2x2 Grid</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 15px;">
        A basic grid with 2 columns and 2 rows of equal size.
    </FluentLabel>
    
    <FluentCard Style="margin-bottom: 30px; padding: 20px;">
        <Grid Columns="1fr 1fr" Rows="100px 100px" Gap="10px">
            <GridItem ColumnStart="1" RowStart="1">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">Cell 1,1</FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="2" RowStart="1">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">Cell 2,1</FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="1" RowStart="2">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">Cell 1,2</FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="2" RowStart="2">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">Cell 2,2</FluentLabel>
                </FluentCard>
            </GridItem>
        </Grid>
        
        <FluentAccordion Style="margin-top: 15px;">
            <FluentAccordionItem Heading="View Code">
                <pre style="background: var(--neutral-layer-2); padding: 15px; border-radius: 4px; overflow-x: auto;"><code>&lt;Grid Columns="1fr 1fr" Rows="100px 100px" Gap="10px"&gt;
    &lt;GridItem ColumnStart="1" RowStart="1"&gt;Cell 1,1&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="2" RowStart="1"&gt;Cell 2,1&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="1" RowStart="2"&gt;Cell 1,2&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="2" RowStart="2"&gt;Cell 2,2&lt;/GridItem&gt;
&lt;/Grid&gt;</code></pre>
            </FluentAccordionItem>
        </FluentAccordion>
    </FluentCard>

    <!-- Example 2: Three Column Layout -->
    <FluentLabel Typo="Typography.H2">2. Three Column Layout</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 15px;">
        A single row with three equal columns, perfect for content sections.
    </FluentLabel>
    
    <FluentCard Style="margin-bottom: 30px; padding: 20px;">
        <Grid Columns="1fr 1fr 1fr" Rows="150px" Gap="15px">
            <GridItem ColumnStart="1" RowStart="1">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; padding: 20px;">
                    <FluentLabel Typo="Typography.H4">Feature 1</FluentLabel>
                    <FluentLabel Typo="Typography.Body">
                        Description of the first feature goes here.
                    </FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="2" RowStart="1">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; padding: 20px;">
                    <FluentLabel Typo="Typography.H4">Feature 2</FluentLabel>
                    <FluentLabel Typo="Typography.Body">
                        Description of the second feature goes here.
                    </FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="3" RowStart="1">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; padding: 20px;">
                    <FluentLabel Typo="Typography.H4">Feature 3</FluentLabel>
                    <FluentLabel Typo="Typography.Body">
                        Description of the third feature goes here.
                    </FluentLabel>
                </FluentCard>
            </GridItem>
        </Grid>
        
        <FluentAccordion Style="margin-top: 15px;">
            <FluentAccordionItem Heading="View Code">
                <pre style="background: var(--neutral-layer-2); padding: 15px; border-radius: 4px; overflow-x: auto;"><code>&lt;Grid Columns="1fr 1fr 1fr" Rows="150px" Gap="15px"&gt;
    &lt;GridItem ColumnStart="1" RowStart="1"&gt;Feature 1&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="2" RowStart="1"&gt;Feature 2&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="3" RowStart="1"&gt;Feature 3&lt;/GridItem&gt;
&lt;/Grid&gt;</code></pre>
            </FluentAccordionItem>
        </FluentAccordion>
    </FluentCard>

    <!-- Example 3: Sidebar Layout -->
    <FluentLabel Typo="Typography.H2">3. Sidebar Layout</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 15px;">
        A classic sidebar layout with a narrow sidebar and wider content area.
    </FluentLabel>
    
    <FluentCard Style="margin-bottom: 30px; padding: 20px;">
        <Grid Columns="200px 1fr" Rows="300px" Gap="15px">
            <GridItem ColumnStart="1" RowStart="1">
                <FluentCard Class="example-card-neutral" Style="height: 100%; padding: 15px;">
                    <FluentLabel Typo="Typography.H5">Sidebar</FluentLabel>
                    <FluentStack Orientation="Orientation.Vertical" Style="margin-top: 15px;">
                        <FluentButton Appearance="Appearance.Lightweight">Menu Item 1</FluentButton>
                        <FluentButton Appearance="Appearance.Lightweight">Menu Item 2</FluentButton>
                        <FluentButton Appearance="Appearance.Lightweight">Menu Item 3</FluentButton>
                        <FluentButton Appearance="Appearance.Lightweight">Menu Item 4</FluentButton>
                    </FluentStack>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="2" RowStart="1">
                <FluentCard Class="example-card-neutral-subtle" Style="height: 100%; padding: 20px;">
                    <FluentLabel Typo="Typography.H4">Main Content</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Style="margin-top: 15px;">
                        This is the main content area. It takes up the remaining space after the sidebar.
                        You can put any content here, and it will automatically adjust to fill the available space.
                    </FluentLabel>
                </FluentCard>
            </GridItem>
        </Grid>
        
        <FluentAccordion Style="margin-top: 15px;">
            <FluentAccordionItem Heading="View Code">
                <pre style="background: var(--neutral-layer-2); padding: 15px; border-radius: 4px; overflow-x: auto;"><code>&lt;Grid Columns="200px 1fr" Rows="300px" Gap="15px"&gt;
    &lt;GridItem ColumnStart="1" RowStart="1"&gt;Sidebar Content&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="2" RowStart="1"&gt;Main Content&lt;/GridItem&gt;
&lt;/Grid&gt;</code></pre>
            </FluentAccordionItem>
        </FluentAccordion>
    </FluentCard>

    <!-- Example 4: Header-Content-Footer Layout -->
    <FluentLabel Typo="Typography.H2">4. Header-Content-Footer Layout</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 15px;">
        A vertical layout with header, main content, and footer sections.
    </FluentLabel>
    
    <FluentCard Style="margin-bottom: 30px; padding: 20px;">
        <Grid Columns="1fr" Rows="60px 1fr 40px" Height="400px" Gap="10px">
            <GridItem ColumnStart="1" RowStart="1">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.H5">Header</FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="1" RowStart="2">
                <FluentCard Class="example-card-neutral-rest" Style="height: 100%; padding: 20px; overflow-y: auto;">
                    <FluentLabel Typo="Typography.H5">Main Content Area</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Style="margin-top: 15px;">
                        This is the main content area that takes up the remaining space between the header and footer.
                        It can contain any amount of content and will scroll if needed.
                    </FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="1" RowStart="3">
                <FluentCard Class="example-card-neutral-strong" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">Footer</FluentLabel>
                </FluentCard>
            </GridItem>
        </Grid>
        
        <FluentAccordion Style="margin-top: 15px;">
            <FluentAccordionItem Heading="View Code">
                <pre style="background: var(--neutral-layer-2); padding: 15px; border-radius: 4px; overflow-x: auto;"><code>&lt;Grid Columns="1fr" Rows="60px 1fr 40px" Height="400px" Gap="10px"&gt;
    &lt;GridItem ColumnStart="1" RowStart="1"&gt;Header&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="1" RowStart="2"&gt;Main Content&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="1" RowStart="3"&gt;Footer&lt;/GridItem&gt;
&lt;/Grid&gt;</code></pre>
            </FluentAccordionItem>
        </FluentAccordion>
    </FluentCard>

    <!-- Example 5: Mixed Size Grid -->
    <FluentLabel Typo="Typography.H2">5. Mixed Size Grid</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="margin-bottom: 15px;">
        A grid with columns of different sizes using mixed units (pixels and fractions).
    </FluentLabel>
    
    <FluentCard Style="margin-bottom: 30px; padding: 20px;">
        <Grid Columns="100px 2fr 1fr" Rows="120px 120px" Gap="10px">
            <GridItem ColumnStart="1" RowStart="1">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">100px</FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="2" RowStart="1">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">2fr (twice as wide)</FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="3" RowStart="1">
                <FluentCard Class="example-card-neutral-subtle" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">1fr</FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="1" RowStart="2">
                <FluentCard Class="example-card-neutral-subtle" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">100px</FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="2" RowStart="2">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">2fr</FluentLabel>
                </FluentCard>
            </GridItem>
            <GridItem ColumnStart="3" RowStart="2">
                <FluentCard Class="example-card-accent-muted" Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <FluentLabel Typo="Typography.Body">1fr</FluentLabel>
                </FluentCard>
            </GridItem>
        </Grid>
        
        <FluentAccordion Style="margin-top: 15px;">
            <FluentAccordionItem Heading="View Code">
                <pre style="background: var(--neutral-layer-2); padding: 15px; border-radius: 4px; overflow-x: auto;"><code>&lt;Grid Columns="100px 2fr 1fr" Rows="120px 120px" Gap="10px"&gt;
    &lt;GridItem ColumnStart="1" RowStart="1"&gt;100px&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="2" RowStart="1"&gt;2fr (twice as wide)&lt;/GridItem&gt;
    &lt;GridItem ColumnStart="3" RowStart="1"&gt;1fr&lt;/GridItem&gt;
    &lt;!-- Second row items... --&gt;
&lt;/Grid&gt;</code></pre>
            </FluentAccordionItem>
        </FluentAccordion>
    </FluentCard>

    <FluentDivider Style="margin: 30px 0;" />

    <FluentMessageBar Intent="MessageIntent.Success">
        <FluentLabel Typo="Typography.Body">
            ?? <strong>Pro Tip:</strong> The "fr" unit represents a fraction of available space. Use it to create flexible, responsive layouts!
        </FluentLabel>
    </FluentMessageBar>
</div>
